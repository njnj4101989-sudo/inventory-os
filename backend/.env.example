# Database — SQLite for dev, PostgreSQL/Supabase for production
# DEV (SQLite - default, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./inventory_os.db
# PRODUCTION (PostgreSQL / Supabase - uncomment when ready):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/inventory_os

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# External API
API_KEY=your-external-api-key-for-drsblouse

# Supabase (Backup)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
BACKUP_BUCKET=inventory-backups

# CORS (comma-separated LAN origins)
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000

# App
APP_ENV=development
