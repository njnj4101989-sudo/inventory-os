# Database — PostgreSQL (local dev + production)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/inventory_dev

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# External API
API_KEY=your-external-api-key

# Supabase (Backup — optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
BACKUP_BUCKET=inventory-backups

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_ENV=development
